# Master Prompt Architect - Environment Variables
# Note: API keys are now configured via the in-app Settings panel
# This file is kept for reference but is no longer required

# Optional: For local development, you can set these env vars
# but the recommended approach is to enter them in the Settings UI

# APP_URL: The URL where this applet is hosted (for local dev)
APP_URL="http://localhost:3000"

# HMR: Disable hot module reload in production
DISABLE_HMR="true"
